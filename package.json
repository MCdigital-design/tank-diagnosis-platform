{
  "name": "tank-diagnosis-platform",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:preview": "cross-env VITE_PREVIEW_AUTH=true VITE_PREVIEW_USER=Z-Float VITE_PREVIEW_PASS=008AAA vite",
    "dev:bg": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-dev.ps1",
    "start": "npm run dev:bg",
    "build": "tsc -b && vite build",
    "build:preview": "tsc -b && cross-env VITE_PREVIEW_AUTH=true VITE_PREVIEW_USER=Z-Float VITE_PREVIEW_PASS=008AAA VITE_BASE_PATH=/ vite build",
    "preview": "vite preview",
    "preview:dist": "npm run build:preview && vite preview",
    "dev:v2": "cross-env VITE_HERO_TANK_MODE=procedural vite",
    "dev:lab": "vite --open /twin-lab/",
    "build:lab": "tsc -b && vite build",
    "blender:hero": "node -e \"console.log('Run ./scripts/blender/export-hero-tank.sh (or .ps1 on Windows) with Blender installed')\"",
    "twin-lab:export-d": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/twin-lab/export-route-d.ps1",
    "twin-lab:export-procedural": "node scripts/twin-lab/export-procedural-glb.mjs all",
    "twin-lab:download-c": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/twin-lab/download-route-c.ps1",
    "twin-lab:package-winner": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/twin-lab/package-winner.ps1",
    "sprint:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/twin-lab/sprint-check.ps1",
    "sprint:autopilot": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/twin-lab/sprint-autopilot.ps1"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/orbitron": "^5.2.8",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "echarts": "^5.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.3",
    "cross-env": "^7.0.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
