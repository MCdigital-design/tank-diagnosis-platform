# Preview deploy — copy to .env.preview.local for local override (gitignored).
# Local dev: leave VITE_PREVIEW_AUTH unset or false.

VITE_PREVIEW_AUTH=false
VITE_PREVIEW_USER=
VITE_PREVIEW_PASS=
VITE_BASE_PATH=/
# Hero tank mode: procedural (DetailedTank) | glb | simple
# After Twin-Lab winner: set glb and add public/models/tank_hero.glb
VITE_HERO_TANK_MODE=procedural
# Legacy: set false → same as VITE_HERO_TANK_MODE=simple
VITE_USE_HERO_GLB=true
