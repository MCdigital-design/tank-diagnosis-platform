{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "罐区智能: dev server (background)",
      "type": "shell",
      "command": "npm run dev:bg",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Local:\\s+http://127\\.0\\.0\\.1:5173|Dev server running at http)"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "close": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "罐区智能: stop dev server",
      "type": "shell",
      "command": "npm run dev:stop",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
